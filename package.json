{
  "name": "@elephant_dev/w.is",
  "version": "3.0.0",
  "description": "Wikipedia lookup CLI — displays color ASCII art and bios of people, places, living things, and things",
  "type": "module",
  "bin": {
    "w.is": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/cli.js --target node --external sharp",
    "prepublish": "bun run build",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:unit": "bun test tests/ascii.test.ts tests/bio.test.ts tests/cli.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --apply src/ tests/",
    "format": "biome format --write src/ tests/"
  },
  "keywords": [
    "wikipedia",
    "cli",
    "ascii-art",
    "lookup"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Elephant-on-github/w-dot-is.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/bun": "^1.3.0",
    "typescript": "^5"
  },
  "dependencies": {
    "sharp": "^0.34.0"
  }
}
